#!/bin/bash
# polarisctl — simple on/off switch for the Polaris background service.
#
#   ./scripts/polarisctl start     # turn it on
#   ./scripts/polarisctl stop      # turn it off (stays off until you start it)
#   ./scripts/polarisctl restart   # pick up code changes (after `npm run build`)
#   ./scripts/polarisctl status    # is it running?
#   ./scripts/polarisctl logs      # tail the log
#
# Wraps launchctl so you never have to remember `gui/$(id -u)/...` syntax.
set -uo pipefail

LABEL="com.polaris.dashboard"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG="$HOME/Library/Logs/polaris-dashboard.log"
TARGET="gui/$(id -u)/$LABEL"
URL="http://127.0.0.1:4000"

is_loaded() { launchctl print "$TARGET" >/dev/null 2>&1; }
is_serving() { curl -sf -o /dev/null --max-time 3 "$URL/api/health"; }

case "${1:-status}" in
  start)
    if is_loaded; then
      echo "Polaris is already running → $URL"
      exit 0
    fi
    [ -f "$PLIST" ] || { echo "Not installed. Run ./scripts/install-autostart.sh first."; exit 1; }
    launchctl bootstrap "gui/$(id -u)" "$PLIST" || exit 1
    echo -n "Starting Polaris"
    for _ in $(seq 1 30); do
      sleep 1; echo -n "."
      if is_serving; then echo " ready → $URL"; exit 0; fi
    done
    echo " (started, but not answering yet — check: $0 logs)"
    ;;

  stop)
    launchctl bootout "$TARGET" 2>/dev/null
    echo "Polaris stopped. It stays off until you run: $0 start"
    echo "(It will also come back on its own at your next login.)"
    ;;

  restart)
    launchctl kickstart -k "$TARGET" 2>/dev/null || { echo "Not running — starting instead."; exec "$0" start; }
    echo -n "Restarting Polaris"
    for _ in $(seq 1 30); do
      sleep 1; echo -n "."
      if is_serving; then echo " ready → $URL"; exit 0; fi
    done
    echo " (restarted, but not answering yet — check: $0 logs)"
    ;;

  status)
    if is_loaded; then
      if is_serving; then echo "Polaris: RUNNING → $URL"
      else echo "Polaris: loaded but not answering on $URL (check: $0 logs)"; fi
    else
      echo "Polaris: STOPPED  (start it with: $0 start)"
    fi
    ;;

  logs)
    echo "Tailing $LOG  (ctrl-C to quit)"
    tail -f "$LOG"
    ;;

  *)
    echo "usage: $0 {start|stop|restart|status|logs}" >&2
    exit 2
    ;;
esac
