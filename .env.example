# Copy to .env and fill in. .env is git-ignored — never commit real values.

# --- Server ---
# Bind address. Keep loopback unless you've put authentication in front of Iris.
HOST=127.0.0.1
PORT=4000
# How often to auto-scan the network, in milliseconds (default 5 min). Lower
# values scan more often but use more CPU/network; 60000 = every minute.
SCAN_INTERVAL_MS=300000
# Re-resolve every device's name (not just unknowns) once every Nth scan, so
# renamed / newly-woken devices refresh. Higher = cheaper but staler names.
NAME_REFRESH_EVERY=6
# Max rows kept in the activity log; older events are pruned each scan.
EVENT_RETENTION=5000

# --- ntfy push notifications (optional) ---
# Full topic URL. Use a LONG, UNGUESSABLE topic — anyone who knows a public
# ntfy.sh topic can read your alerts. Leave unset to disable notifications.
# NTFY_URL=https://ntfy.sh/iris-home-CHANGE-ME-8fk39dk2mx7
# Optional bearer token for protected or self-hosted ntfy servers.
# NTFY_TOKEN=tk_xxxxxxxxxxxxxxxxxxxx
# Optional default priority: min | low | default | high | urgent
# NTFY_PRIORITY=high
